@model IEnumerable<RestaurantFoodOrderingCustomer.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<!-- My Orders Page Container -->
<div class="container my-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-receipt me-2"></i>My Orders
        </h2>
        <a href="@Url.Action("OrderHistory")" class="btn btn-outline-success">
            <i class="fas fa-history me-2"></i>View Order History
        </a>
    </div>

    <!-- Filter Section -->
    <div class="card mb-4 filter-card">
        <div class="card-body">
            <form method="get" asp-action="MyOrders" id="filterForm">
                <div class="row g-3 align-items-end">
                    <!-- Search Filter -->
                    <div class="col-md-9">
                        <label for="searchTerm" class="form-label">
                            <i class="fas fa-search me-1"></i>Search Orders
                        </label>
                        <input type="text" 
                               class="form-control" 
                               id="searchTerm" 
                               name="searchTerm"
                               value="@ViewBag.SearchTerm"
                               placeholder="Search by Order ID or Food Name...">
                    </div>

                    <!-- Filter Buttons -->
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary-custom w-100 mb-1">
                            <i class="fas fa-search me-1"></i>Search
                        </button>
                        <a href="@Url.Action("MyOrders")" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-redo me-1"></i>Clear
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Count -->
    @if (Model.Any())
    {
        <div class="alert alert-info mb-3">
            <i class="fas fa-info-circle me-2"></i>
            Showing <strong>@Model.Count()</strong> active order(s)
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
            {
                <span> matching "<strong>@ViewBag.SearchTerm</strong>"</span>
            }
        </div>
    }

    <!-- Orders List -->
    @if (Model.Any())
    {
        <div class="row">
            @foreach (var order in Model)
            {
                <div class="col-md-12 mb-4">
                    <!-- Order Card -->
                    <div class="card">
                        <!-- Order Header -->
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0">Order #@order.OrderId</h5>
                                <small class="text-muted">@order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</small>
                            </div>
                            <!-- Order Status Badge -->
                            <div>
                                @if (order.Status == "Pending")
                                {
                                    <span class="badge status-pending">@order.Status</span>
                                }
                                else if (order.Status == "Confirmed")
                                {
                                    <span class="badge status-confirmed">@order.Status</span>
                                }
                                else if (order.Status == "Preparing")
                                {
                                    <span class="badge status-preparing">@order.Status</span>
                                }
                                else if (order.Status == "Delivered")
                                {
                                    <span class="badge status-delivered">@order.Status</span>
                                }
                                else
                                {
                                    <span class="badge status-cancelled">@order.Status</span>
                                }
                            </div>
                        </div>
                        <!-- Order Body -->
                        <div class="card-body">
                            <!-- Delivery Success Message -->
                            @if (order.Status == "Delivered")
                            {
                                <div class="alert alert-success mb-3">
                                    <i class="fas fa-check-circle me-2"></i>
                                    <strong>Order Delivered!</strong> How was your experience? Rate the items below.
                                </div>
                            }
                            <div class="row">
                                <!-- Order Items Column -->
                                <div class="col-md-8">
                                    <h6 class="mb-3">Order Items:</h6>
                                    <!-- Loop Order Items -->
                                    @if (order.OrderItems != null)
                                    {
                                        @foreach (var item in order.OrderItems)
                                        {
                                            <div class="d-flex align-items-center mb-2 p-2 order-item-row">
                                                @if (!string.IsNullOrEmpty(item.FoodItem?.ImageUrl))
                                                {
                                                    <img src="@item.FoodItem.ImageUrl" alt="@item.FoodItem.FoodName" 
                                                         class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                                }
                                                <div class="flex-grow-1">
                                                    <strong>@item.FoodItem?.FoodName</strong>
                                                    <span class="text-muted"> x @item.Quantity</span>
                                                    <!-- Rate & Review Button -->
                                                    @if (order.Status == "Delivered")
                                                    {
                                                        <br>
                                                        <a href="@Url.Action("Create", "Review", new { foodId = item.FoodId, orderId = order.OrderId })" 
                                                           class="btn btn-sm btn-warning mt-1">
                                                            <i class="fas fa-star me-1"></i>Rate & Review
                                                        </a>
                                                    }
                                                </div>
                                                <div>
                                                    <strong>₹@item.TotalPrice</strong>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                                <!-- Order Summary Column -->
                                <div class="col-md-4">
                                    <div class="bg-light p-3 rounded">
                                        <h6>Order Summary</h6>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Total Amount:</span>
                                            <strong>₹@order.TotalAmount</strong>
                                        </div>
                                        <!-- Payment Method -->
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Payment:</span>
                                            <strong>
                                                @if (order.PaymentMethod == "Cash on Delivery")
                                                {
                                                    <i class="fas fa-money-bill-wave text-success me-1"></i>
                                                }
                                                else if (order.PaymentMethod == "Credit/Debit Card")
                                                {
                                                    <i class="fas fa-credit-card text-primary me-1"></i>
                                                }
                                                else if (order.PaymentMethod == "UPI")
                                                {
                                                    <i class="fas fa-mobile-alt text-info me-1"></i>
                                                }
                                                else if (order.PaymentMethod == "Net Banking")
                                                {
                                                    <i class="fas fa-university text-warning me-1"></i>
                                                }
                                                @order.PaymentMethod
                                            </strong>
                                        </div>
                                        <!-- Payment Status -->
                                        @if (order.PaymentStatus == "Paid")
                                        {
                                            <div class="text-center mb-2">
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check-circle me-1"></i>Payment Completed
                                                </span>
                                            </div>
                                        }
                                        <hr>
                                        <!-- Delivery Details -->
                                        <p class="mb-2"><small><strong>Delivery Address:</strong></small></p>
                                        <p class="text-muted small">@order.DeliveryAddress</p>
                                        @if (!string.IsNullOrEmpty(order.ContactPhone))
                                        {
                                            <p class="mb-0"><small><strong>Phone:</strong> @order.ContactPhone</small></p>
                                        }
                                    </div>
                                    <!-- Action Buttons -->
                                    <div class="mt-3">
                                        <a href="@Url.Action("OrderDetails", new { id = order.OrderId })" class="btn btn-primary-custom btn-sm w-100 mb-2">
                                            <i class="fas fa-eye me-2"></i>View Details
                                        </a>
                                        @if (order.Status != "Cancelled")
                                        {
                                            <button type="button" class="btn btn-success btn-sm w-100" data-bs-toggle="modal" data-bs-target="#trackModal@(order.OrderId)">
                                                <i class="fas fa-map-marker-alt me-2"></i>Track Order
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Track Order Modal -->
                    <div class="modal fade" id="trackModal@(order.OrderId)" tabindex="-1" aria-labelledby="trackModalLabel@(order.OrderId)" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="trackModalLabel@(order.OrderId)">
                                        <i class="fas fa-map-marker-alt me-2"></i>Track Order #@order.OrderId
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <!-- Order Timeline -->
                                    <div class="tracking-timeline">
                                        <!-- Pending -->
                                        <div class="timeline-item @(order.Status == "Pending" || order.Status == "Confirmed" || order.Status == "Preparing" || order.Status == "Delivered" ? "completed" : "")">
                                            <div class="timeline-marker">
                                                <i class="fas fa-check"></i>
                                            </div>
                                            <div class="timeline-content">
                                                <h6>Order Placed</h6>
                                                <p class="text-muted small mb-0">@order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</p>
                                            </div>
                                        </div>

                                        <!-- Confirmed -->
                                        <div class="timeline-item @(order.Status == "Confirmed" || order.Status == "Preparing" || order.Status == "Delivered" ? "completed" : (order.Status == "Pending" ? "active" : ""))">
                                            <div class="timeline-marker">
                                                <i class="fas fa-@(order.Status == "Confirmed" || order.Status == "Preparing" || order.Status == "Delivered" ? "check" : (order.Status == "Pending" ? "clock" : "circle"))"></i>
                                            </div>
                                            <div class="timeline-content">
                                                <h6>Order Confirmed</h6>
                                                <p class="text-muted small mb-0">@(order.Status == "Confirmed" || order.Status == "Preparing" || order.Status == "Delivered" ? "Confirmed by restaurant" : "Waiting for confirmation")</p>
                                            </div>
                                        </div>

                                        <!-- Preparing -->
                                        <div class="timeline-item @(order.Status == "Preparing" || order.Status == "Delivered" ? "completed" : (order.Status == "Confirmed" ? "active" : ""))">
                                            <div class="timeline-marker">
                                                <i class="fas fa-@(order.Status == "Preparing" || order.Status == "Delivered" ? "check" : (order.Status == "Confirmed" ? "clock" : "circle"))"></i>
                                            </div>
                                            <div class="timeline-content">
                                                <h6>Preparing Food</h6>
                                                <p class="text-muted small mb-0">@(order.Status == "Preparing" || order.Status == "Delivered" ? "Your food is being prepared" : "Will start soon")</p>
                                            </div>
                                        </div>

                                        <!-- Out for Delivery -->
                                        <div class="timeline-item @(order.Status == "Delivered" ? "completed" : (order.Status == "Preparing" ? "active" : ""))">
                                            <div class="timeline-marker">
                                                <i class="fas fa-@(order.Status == "Delivered" ? "check" : (order.Status == "Preparing" ? "shipping-fast" : "circle"))"></i>
                                            </div>
                                            <div class="timeline-content">
                                                <h6>Out for Delivery</h6>
                                                <p class="text-muted small mb-0">@(order.Status == "Delivered" ? "Order was delivered" : (order.Status == "Preparing" ? "Will deliver soon" : "Pending"))</p>
                                            </div>
                                        </div>

                                        <!-- Delivered -->
                                        <div class="timeline-item @(order.Status == "Delivered" ? "completed" : "")">
                                            <div class="timeline-marker">
                                                <i class="fas fa-@(order.Status == "Delivered" ? "check-circle" : "circle")"></i>
                                            </div>
                                            <div class="timeline-content">
                                                <h6>Delivered</h6>
                                                <p class="text-muted small mb-0">
                                                    @if (order.Status == "Delivered" && order.DeliveryDate.HasValue)
                                                    {
                                                        @order.DeliveryDate.Value.ToString("dd MMM yyyy, hh:mm tt")
                                                    }
                                                    else
                                                    {
                                                        <text>Your order will arrive soon!</text>
                                                    }
                                                </p>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Current Status Info -->
                                    <div class="alert @(order.Status == "Delivered" ? "alert-success" : "alert-info") mt-3 mb-0">
                                        <strong>Current Status:</strong> 
                                        @if (order.Status == "Pending")
                                        {
                                            <span class="badge status-pending ms-2">Pending</span>
                                            <p class="mb-0 mt-2 small">Your order is waiting for restaurant confirmation.</p>
                                        }
                                        else if (order.Status == "Confirmed")
                                        {
                                            <span class="badge status-confirmed ms-2">Confirmed</span>
                                            <p class="mb-0 mt-2 small">Restaurant has confirmed your order. Food preparation will start soon.</p>
                                        }
                                        else if (order.Status == "Preparing")
                                        {
                                            <span class="badge status-preparing ms-2">Preparing</span>
                                            <p class="mb-0 mt-2 small">Your delicious food is being prepared! Delivery will start soon.</p>
                                        }
                                        else if (order.Status == "Delivered")
                                        {
                                            <span class="badge status-delivered ms-2">Delivered</span>
                                            <p class="mb-0 mt-2 small">
                                                <i class="fas fa-check-circle text-success me-1"></i>
                                                Your order has been successfully delivered! We hope you enjoyed your meal.
                                                @if (order.DeliveryDate.HasValue)
                                                {
                                                    <br><strong>Delivered on:</strong> @order.DeliveryDate.Value.ToString("dd MMM yyyy, hh:mm tt")
                                                }
                                            </p>
                                        }
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    <!-- No Orders Empty State -->
    else
    {
        <div class="text-center my-5 py-5">
            <i class="fas fa-inbox fa-5x text-muted mb-4"></i>
            <h3>No Active Orders</h3>
            <p class="text-muted mb-4">You don't have any active orders right now.</p>
            <a href="@Url.Action("Menu", "Home")" class="btn btn-primary-custom btn-lg me-2">
                <i class="fas fa-utensils me-2"></i>Browse Menu
            </a>
            <a href="@Url.Action("OrderHistory")" class="btn btn-outline-success btn-lg">
                <i class="fas fa-history me-2"></i>View Order History
            </a>
        </div>
    }
</div>

<style>
    .btn-primary-custom {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
    }

    .btn-primary-custom:hover {
        background-color: #9a0e19;
        border-color: #9a0e19;
    }
    
    .order-item-row {
        background-color: #f8f9fa;
        border-radius: 8px;
        transition: all 0.3s ease;
    }
    
    .order-item-row:hover {
        background-color: #e9ecef;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .btn-warning {
        background-color: #ffc107;
        border-color: #ffc107;
        color: #000;
        font-weight: 500;
    }
    
    .btn-warning:hover {
        background-color: #ffca2c;
        border-color: #ffca2c;
        color: #000;
        box-shadow: 0 2px 8px rgba(255, 193, 7, 0.4);
    }

    /* Filter Card Styles */
    .filter-card {
        border: none;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        border-radius: 10px;
    }

    .filter-card .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 0.5rem;
    }

    .filter-card .form-control,
    .filter-card .form-select {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 0.6rem 1rem;
        transition: all 0.3s ease;
    }

    .filter-card .form-control:focus,
    .filter-card .form-select:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 0.2rem rgba(184, 14, 27, 0.15);
    }

    /* Tracking Timeline Styles */
    .tracking-timeline {
        position: relative;
        padding: 20px 0;
    }

    .timeline-item {
        display: flex;
        gap: 15px;
        position: relative;
        padding-bottom: 30px;
    }

    .timeline-item:last-child {
        padding-bottom: 0;
    }

    .timeline-item::before {
        content: '';
        position: absolute;
        left: 19px;
        top: 40px;
        width: 2px;
        height: calc(100% - 10px);
        background: #e0e0e0;
    }

    .timeline-item:last-child::before {
        display: none;
    }

    .timeline-item.completed::before {
        background: #28a745;
    }

    .timeline-item.active::before {
        background: linear-gradient(to bottom, #28a745 0%, #e0e0e0 100%);
    }

    .timeline-marker {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #e0e0e0;
        color: #999;
        font-size: 16px;
        flex-shrink: 0;
        z-index: 1;
        transition: all 0.3s ease;
    }

    .timeline-item.completed .timeline-marker {
        background: #28a745;
        color: white;
        box-shadow: 0 0 0 4px rgba(40, 167, 69, 0.2);
    }

    .timeline-item.active .timeline-marker {
        background: #ffc107;
        color: white;
        animation: pulse 2s infinite;
        box-shadow: 0 0 0 4px rgba(255, 193, 7, 0.3);
    }

    @keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    .timeline-content {
        flex: 1;
        padding-top: 5px;
    }

    .timeline-content h6 {
        margin: 0 0 5px 0;
        font-weight: 600;
        color: #333;
    }

    .timeline-item.completed .timeline-content h6 {
        color: #28a745;
    }

    .timeline-item.active .timeline-content h6 {
        color: #ffc107;
        font-weight: 700;
    }

    /* Alert Info in Modal */
    .modal-body .alert-info {
        background-color: #e7f3ff;
        border-color: #b3d9ff;
        color: #004085;
    }

    .modal-body .alert-success {
        background-color: #d4edda;
        border-color: #c3e6cb;
        color: #155724;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .filter-card .row > div {
            margin-bottom: 10px;
        }

        .timeline-item {
            gap: 10px;
        }

        .timeline-marker {
            width: 35px;
            height: 35px;
            font-size: 14px;
        }

        .timeline-item::before {
            left: 16.5px;
        }
    }
</style>
