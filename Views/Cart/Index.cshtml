@model List<RestaurantFoodOrderingCustomer.Models.CartItem>
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container my-4">
    <h2 class="mb-4">
        <i class="fas fa-shopping-cart me-2"></i>Your Cart
    </h2>

    @if (Model.Any())
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-body">
                        @foreach (var item in Model)
                        {
                            <div class="row mb-3 pb-3 border-bottom">
                                <div class="col-md-2">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.FoodName" class="img-fluid rounded">
                                    }
                                </div>
                                <div class="col-md-4">
                                    <h5>@item.FoodName</h5>
                                    <p class="text-muted mb-0">₹@item.Price</p>
                                </div>
                                <div class="col-md-3">
                                    <div class="input-group">
                                        <button class="btn btn-outline-secondary" type="button" 
                                                onclick="updateQuantity(@item.FoodId, @(item.Quantity - 1))">
                                            <i class="fas fa-minus"></i>
                                        </button>
                                        <input type="text" class="form-control text-center quantity-input" 
                                               value="@item.Quantity" readonly>
                                        <button class="btn btn-outline-secondary" type="button" 
                                                onclick="updateQuantity(@item.FoodId, @(item.Quantity + 1))">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="col-md-2 text-end">
                                    <h5>₹@item.TotalPrice</h5>
                                </div>
                                <div class="col-md-1 text-end">
                                    <button class="btn btn-danger btn-sm" onclick="removeFromCart(@item.FoodId)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-primary-custom text-white">
                        <h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <strong>₹@Model.Sum(i => i.TotalPrice)</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Delivery Fee:</span>
                            <strong>₹40</strong>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <h5>Total:</h5>
                            <h5 class="text-primary-custom">₹@(Model.Sum(i => i.TotalPrice) + 40)</h5>
                        </div>
                        <a href="@Url.Action("Checkout", "Order")" class="btn btn-primary-custom w-100 py-2">
                            <i class="fas fa-check me-2"></i>Proceed to Checkout
                        </a>
                        <a href="@Url.Action("Menu", "Home")" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="fas fa-arrow-left me-2"></i>Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center my-5">
            <i class="fas fa-shopping-cart fa-5x text-muted mb-4"></i>
            <h3>Your cart is empty</h3>
            <p class="text-muted mb-4">Start adding delicious food items to your cart!</p>
            <a href="@Url.Action("Menu", "Home")" class="btn btn-primary-custom btn-lg">
                <i class="fas fa-utensils me-2"></i>Browse Menu
            </a>
        </div>
    }
</div>

<style>
    .bg-primary-custom {
        background-color: var(--primary-color) !important;
    }

    .text-primary-custom {
        color: var(--primary-color) !important;
    }
</style>
