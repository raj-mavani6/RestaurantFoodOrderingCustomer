@model RestaurantFoodOrderingCustomer.Models.FoodItem
@{
    ViewData["Title"] = Model.FoodName;
}

<!-- Food Details Container -->
<div class="container my-5">
    <div class="row">
        <!-- Food Image -->
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.FoodName" class="img-fluid rounded shadow">
            }
            else
            {
                <img src="https://via.placeholder.com/600x500?text=Food+Image" alt="@Model.FoodName" class="img-fluid rounded shadow">
            }
        </div>

        <!-- Food Information -->
        <div class="col-md-6">
            <!-- Food Name & Veg/Non-Veg Indicator -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>@Model.FoodName</h2>
                @if (Model.IsVeg)
                {
                    <span class="veg-indicator" title="Vegetarian"></span>
                }
                else
                {
                    <span class="non-veg-indicator" title="Non-Vegetarian"></span>
                }
            </div>

            <!-- Price -->
            <h3 class="text-primary-custom mb-4">₹@Model.Price</h3>

            <!-- Description -->
            <div class="mb-4">
                <h5>Description</h5>
                <p class="text-muted">
                    @(string.IsNullOrEmpty(Model.Description) ? "Delicious food item from our menu." : Model.Description)
                </p>
            </div>

            <!-- Category -->
            <div class="mb-4">
                <h5>Category</h5>
                <span class="badge bg-secondary-custom">@Model.Category?.CategoryName</span>
            </div>

            <!-- Availability Status -->
            <div class="mb-4">
                <h5>Availability</h5>
                @if (Model.IsAvailable)
                {
                    <span class="badge bg-success">Available</span>
                }
                else
                {
                    <span class="badge bg-danger">Out of Stock</span>
                }
            </div>

            @if (Model.IsAvailable)
            {
                <!-- Quantity Selector -->
                <div class="mb-4">
                    <label for="quantity" class="form-label"><h5>Quantity</h5></label>
                    <div class="input-group" style="max-width: 150px;">
                        <button class="btn btn-outline-secondary" type="button" onclick="decrementQuantity('quantity')">
                            <i class="fas fa-minus"></i>
                        </button>
                        <input type="number" class="form-control text-center" id="quantity" value="1" min="1" max="10">
                        <button class="btn btn-outline-secondary" type="button" onclick="incrementQuantity('quantity')">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="d-grid gap-2">
                    <button class="btn btn-primary-custom btn-lg" onclick="addToCartWithQuantity(@Model.FoodId)">
                        <i class="fas fa-cart-plus me-2"></i>Add to Cart
                    </button>
                    <a href="@Url.Action("Menu", "Home")" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Back to Menu
                    </a>
                </div>
            }
            <!-- Out of Stock Alert -->
            else
            {
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    This item is currently unavailable
                </div>
                <a href="@Url.Action("Menu", "Home")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to Menu
                </a>
            }
        </div>
    </div>

    <!-- Reviews Section -->
    <div class="row mt-5">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary-custom text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="fas fa-star me-2"></i>Ratings & Reviews
                        </h4>
                        @if (Context.Session.GetInt32("CustomerId") != null)
                        {
                            @if (ViewBag.HasReviewed == true)
                            {
                                <span class="badge bg-success">You have reviewed this item</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Create", "Review", new { foodId = Model.FoodId })" 
                                   class="btn btn-light btn-sm">
                                    <i class="fas fa-pen me-1"></i>Write a Review
                                </a>
                            }
                        }
                    </div>
                </div>
                <div class="card-body">
                    @if (ViewBag.TotalReviews > 0)
                    {
                        <!-- Average Rating Summary -->
                        <div class="rating-summary mb-4">
                            <div class="row">
                                <!-- Rating Score -->
                                <div class="col-md-3 text-center border-end">
                                    <h1 class="display-3 mb-0">@ViewBag.AverageRating.ToString("F1")</h1>
                                    <div class="stars-large mb-2">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= Math.Round((double)ViewBag.AverageRating))
                                            {
                                                <i class="fas fa-star text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="far fa-star text-warning"></i>
                                            }
                                        }
                                    </div>
                                    <p class="text-muted mb-0">@ViewBag.TotalReviews Reviews</p>
                                </div>
                                <!-- Reviews List -->
                                <div class="col-md-9">
                                    <h5 class="mb-3">Customer Reviews</h5>
                                    <!-- Individual Reviews -->
                                    @foreach (var review in (List<RestaurantFoodOrderingCustomer.Models.Review>)ViewBag.Reviews)
                                    {
                                        <div class="review-item mb-3 pb-3 border-bottom">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <h6 class="mb-1">@review.Customer?.FullName</h6>
                                                    <div class="stars mb-2">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            if (i <= review.Rating)
                                                            {
                                                                <i class="fas fa-star text-warning"></i>
                                                            }
                                                            else
                                                            {
                                                                <i class="far fa-star text-warning"></i>
                                                            }
                                                        }
                                                        <span class="ms-2 text-muted">(@review.Rating/5)</span>
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(review.Comment))
                                                    {
                                                        <p class="review-text mb-0">@review.Comment</p>
                                                    }
                                                </div>
                                                <small class="text-muted">
                                                    @review.ReviewDate.ToString("dd MMM yyyy")
                                                </small>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    <!-- No Reviews -->
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-star fa-4x text-muted mb-3"></i>
                            <h5>No Reviews Yet</h5>
                            <p class="text-muted">Be the first to review this item!</p>
                            @if (Context.Session.GetInt32("CustomerId") != null)
                            {
                                <a href="@Url.Action("Create", "Review", new { foodId = Model.FoodId })" 
                                   class="btn btn-primary-custom">
                                    <i class="fas fa-pen me-2"></i>Write a Review
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<!-- Add to Cart Script -->
<script>
    function addToCartWithQuantity(foodId) {
        var quantity = parseInt(document.getElementById('quantity').value);
        addToCart(foodId, quantity);
    }
</script>
}

<style>
    .text-primary-custom {
        color: var(--primary-color);
    }
    
    .bg-secondary-custom {
        background-color: var(--secondary-color);
    }
    
    .bg-primary-custom {
        background-color: var(--primary-color) !important;
    }
    
    .btn-primary-custom {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
    }
    
    .btn-primary-custom:hover {
        background-color: #a00e1a;
        border-color: #a00e1a;
    }
    
    .stars-large {
        font-size: 1.5rem;
    }
    
    .review-item {
        background-color: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
    }
    
    .review-text {
        font-style: italic;
        color: #555;
        margin-top: 10px;
    }
</style>
