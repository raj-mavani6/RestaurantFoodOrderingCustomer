@model IEnumerable<RestaurantFoodOrderingCustomer.Models.FoodItem>
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <h1><i class="fas fa-utensils me-3"></i>Welcome to Tasty Bites</h1>
        <p class="lead">Delicious food delivered hot and fresh to your doorstep</p>
        <a href="@Url.Action("Menu", "Home")" class="btn btn-light btn-lg mt-3">
            <i class="fas fa-book-open me-2"></i>View Menu
        </a>
    </div>
</section>

<!-- Categories Section with Carousel -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-4">
            <i class="fas fa-th-large me-2"></i>Browse by Category
        </h2>
        <div class="category-carousel-wrapper">
            <!-- Left Arrow -->
            <button class="carousel-arrow carousel-arrow-left" id="catPrev" title="Previous">
                <i class="fas fa-chevron-left"></i>
            </button>

            <!-- Carousel Track -->
            <div class="category-carousel-viewport">
                <div class="category-carousel-track" id="categoryTrack">
                    @foreach (var category in ViewBag.Categories)
                    {
                        <div class="category-carousel-item">
                            <a href="@Url.Action("Menu", "Home", new { categoryId = category.CategoryId })" class="text-decoration-none">
                                <div class="category-card">
                                    @if (!string.IsNullOrEmpty(category.ImageUrl))
                                    {
                                        <img src="@category.ImageUrl" alt="@category.CategoryName" class="img-fluid">
                                    }
                                    else
                                    {
                                        <i class="fas fa-utensils fa-3x text-primary-custom mb-3"></i>
                                    }
                                    <h5>@category.CategoryName</h5>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Right Arrow -->
            <button class="carousel-arrow carousel-arrow-right" id="catNext" title="Next">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </div>
</section>

<style>
    /* Category Carousel */
    .category-carousel-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .category-carousel-viewport {
        overflow: hidden;
        flex: 1;
    }

    .category-carousel-track {
        display: flex;
        gap: 20px;
        transition: transform 0.5s ease;
    }

    .category-carousel-item {
        min-width: calc((100% - 100px) / 6);
        flex-shrink: 0;
    }

    .carousel-arrow {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        border: 2px solid #C1121F;
        background: white;
        color: #C1121F;
        font-size: 18px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        z-index: 2;
    }

    .carousel-arrow:hover {
        background: #C1121F;
        color: white;
        transform: scale(1.1);
        box-shadow: 0 4px 15px rgba(193, 18, 31, 0.3);
    }

    .carousel-arrow:disabled {
        opacity: 0.3;
        cursor: not-allowed;
        transform: none;
    }

    .carousel-arrow:disabled:hover {
        background: white;
        color: #C1121F;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    /* Responsive: show fewer items on smaller screens */
    @@media (max-width: 992px) {
        .category-carousel-item {
            min-width: calc((100% - 60px) / 4);
        }
    }

    @@media (max-width: 768px) {
        .category-carousel-item {
            min-width: calc((100% - 40px) / 3);
        }
    }

    @@media (max-width: 576px) {
        .category-carousel-item {
            min-width: calc((100% - 20px) / 2);
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const track = document.getElementById('categoryTrack');
        const prevBtn = document.getElementById('catPrev');
        const nextBtn = document.getElementById('catNext');

        if (!track || !prevBtn || !nextBtn) return;

        const items = track.querySelectorAll('.category-carousel-item');
        const totalItems = items.length;
        let currentIndex = 0;
        let visibleCount = 6;

        function getVisibleCount() {
            const width = window.innerWidth;
            if (width <= 576) return 2;
            if (width <= 768) return 3;
            if (width <= 992) return 4;
            return 6;
        }

        function getItemWidth() {
            if (items.length === 0) return 0;
            const gap = 20;
            const viewportWidth = track.parentElement.offsetWidth;
            return (viewportWidth - (gap * (visibleCount - 1))) / visibleCount + gap;
        }

        function updateCarousel() {
            visibleCount = getVisibleCount();
            const maxIndex = Math.max(0, totalItems - visibleCount);
            if (currentIndex > maxIndex) currentIndex = maxIndex;

            const itemWidth = getItemWidth();
            track.style.transform = `translateX(-${currentIndex * itemWidth}px)`;

            prevBtn.disabled = currentIndex <= 0;
            nextBtn.disabled = currentIndex >= maxIndex;
        }

        prevBtn.addEventListener('click', function () {
            if (currentIndex > 0) {
                currentIndex--;
                updateCarousel();
            }
        });

        nextBtn.addEventListener('click', function () {
            const maxIndex = Math.max(0, totalItems - visibleCount);
            if (currentIndex < maxIndex) {
                currentIndex++;
                updateCarousel();
            }
        });

        window.addEventListener('resize', updateCarousel);
        updateCarousel();
    });
</script>

<!-- Featured Items Section -->
<section class="py-5 bg-white">
    <div class="container">
        <h2 class="text-center mb-4">
            <i class="fas fa-star me-2"></i>Featured Items
        </h2>
        <div class="row g-4">
            @foreach (var item in Model.Take(6))
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top food-card-img" alt="@item.FoodName">
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/300x250?text=Food+Item" class="card-img-top food-card-img" alt="@item.FoodName">
                        }
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="card-title mb-0">@item.FoodName</h5>
                                @if (item.IsVeg)
                                {
                                    <span class="veg-indicator" title="Vegetarian"></span>
                                }
                                else
                                {
                                    <span class="non-veg-indicator" title="Non-Vegetarian"></span>
                                }
                            </div>
                            <p class="card-text text-muted">
                                @(item.Description?.Length > 80 ? item.Description.Substring(0, 80) + "..." : item.Description)
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="price-badge">₹@item.Price</span>
                                <div class="action-buttons">
                                    <a href="@Url.Action("FoodDetails", "Home", new { id = item.FoodId })" 
                                       class="btn-icon btn-details" 
                                       title="View Details">
                                        <i class="fas fa-info"></i>
                                    </a>
                                    <button class="btn-icon btn-add-cart" 
                                            onclick="addToCart(@item.FoodId)" 
                                            title="Add to Cart">
                                        <i class="fas fa-shopping-cart"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-4">
            <a href="@Url.Action("Menu", "Home")" class="btn btn-secondary-custom btn-lg">
                <i class="fas fa-eye me-2"></i>View All Items
            </a>
        </div>
    </div>
</section>

<!-- Why Choose Us Section -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-5">
            <i class="fas fa-check-circle me-2"></i>Why Choose Us
        </h2>
        <div class="row g-4">
            <div class="col-md-4 text-center">
                <i class="fas fa-shipping-fast fa-3x text-primary-custom mb-3"></i>
                <h4>Fast Delivery</h4>
                <p class="text-muted">Get your food delivered hot and fresh within 30 minutes</p>
            </div>
            <div class="col-md-4 text-center">
                <i class="fas fa-utensils fa-3x text-primary-custom mb-3"></i>
                <h4>Quality Food</h4>
                <p class="text-muted">Fresh ingredients and authentic recipes</p>
            </div>
            <div class="col-md-4 text-center">
                <i class="fas fa-headset fa-3x text-primary-custom mb-3"></i>
                <h4>24/7 Support</h4>
                <p class="text-muted">Our team is always here to help you</p>
            </div>
        </div>
    </div>
</section>

<style>
    .text-primary-custom {
        color: var(--primary-color);
    }
</style>
