@{
    ViewData["Title"] = "About Us";
}

<!-- Hero Section -->
<section class="about-hero" style="background: linear-gradient(135deg, #C1121F 0%, #FF8500 100%); padding: 80px 0; color: white;">
    <div class="container text-center">
        <h1 class="display-3 fw-bold mb-3">
            <i class="fas fa-utensils me-3"></i>About Tasty Bites
        </h1>
        <p class="lead fs-4">Delicious Food, Delivered with Love</p>
    </div>
</section>

<!-- Our Story Section -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=800&h=600&fit=crop" 
                     alt="Restaurant" class="img-fluid rounded shadow-lg">
            </div>
            <div class="col-lg-6">
                <h2 class="display-5 fw-bold mb-4">
                    <i class="fas fa-heart me-2" style="color: #C1121F;"></i>Our Story
                </h2>
                <p class="lead text-muted mb-4">
                    Founded in 2020, Tasty Bites has been serving delicious and authentic food 
                    to our valued customers with passion and dedication.
                </p>
                <p class="text-muted mb-4">
                    We believe in using only the freshest ingredients and traditional recipes 
                    to create memorable dining experiences. Our chefs bring years of expertise 
                    and love for cooking to every dish we serve.
                </p>
                <p class="text-muted">
                    Whether you're craving comfort food, trying something new, or celebrating 
                    a special occasion, Tasty Bites is here to make every meal special.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Vision Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col">
                <h2 class="display-5 fw-bold mb-3">Mission & Vision</h2>
                <p class="lead text-muted">What drives us every day</p>
            </div>
        </div>
        <div class="row">
            <!-- Mission Card -->
            <div class="col-md-6 mb-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="text-center mb-3">
                            <i class="fas fa-bullseye fa-3x" style="color: #C1121F;"></i>
                        </div>
                        <h3 class="card-title text-center fw-bold mb-3">Our Mission</h3>
                        <p class="card-text text-muted">
                            To provide exceptional dining experiences by delivering high-quality, 
                            delicious food with outstanding customer service. We strive to exceed 
                            expectations with every order and make every customer feel valued.
                        </p>
                    </div>
                </div>
            </div>
            <!-- Vision Card -->
            <div class="col-md-6 mb-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="text-center mb-3">
                            <i class="fas fa-eye fa-3x" style="color: #6A994E;"></i>
                        </div>
                        <h3 class="card-title text-center fw-bold mb-3">Our Vision</h3>
                        <p class="card-text text-muted">
                            To become the most loved and trusted food delivery service, known for 
                            our quality, reliability, and innovation. We aim to bring joy to every 
                            table and create lasting memories through great food.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Our Values Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Our Core Values</h2>
            <p class="lead text-muted">The principles that guide everything we do</p>
        </div>
        <div class="row">
            <!-- Quality First -->
            <div class="col-md-4 mb-4">
                <div class="text-center">
                    <div class="mb-3">
                        <i class="fas fa-award fa-4x" style="color: #FF8500;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Quality First</h4>
                    <p class="text-muted">
                        We never compromise on quality. Every ingredient is carefully selected 
                        and every dish is prepared with care and attention to detail.
                    </p>
                </div>
            </div>
            <!-- Customer Focus -->
            <div class="col-md-4 mb-4">
                <div class="text-center">
                    <div class="mb-3">
                        <i class="fas fa-users fa-4x" style="color: #FF8500;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Customer Focus</h4>
                    <p class="text-muted">
                        Your satisfaction is our priority. We listen to feedback and continuously 
                        improve to serve you better.
                    </p>
                </div>
            </div>
            <!-- Sustainability -->
            <div class="col-md-4 mb-4">
                <div class="text-center">
                    <div class="mb-3">
                        <i class="fas fa-leaf fa-4x" style="color: #6A994E;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Sustainability</h4>
                    <p class="text-muted">
                        We care about our planet. We use eco-friendly packaging and support 
                        local suppliers whenever possible.
                    </p>
                </div>
            </div>
            <!-- Timely Delivery -->
            <div class="col-md-4 mb-4">
                <div class="text-center">
                    <div class="mb-3">
                        <i class="fas fa-clock fa-4x" style="color: #C1121F;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Timely Delivery</h4>
                    <p class="text-muted">
                        We value your time. Our efficient delivery system ensures your food 
                        arrives fresh and on time, every time.
                    </p>
                </div>
            </div>
            <!-- Safety & Hygiene -->
            <div class="col-md-4 mb-4">
                <div class="text-center">
                    <div class="mb-3">
                        <i class="fas fa-shield-alt fa-4x" style="color: #C1121F;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Safety & Hygiene</h4>
                    <p class="text-muted">
                        We maintain the highest standards of food safety and hygiene in our 
                        kitchen and throughout the delivery process.
                    </p>
                </div>
            </div>
            <!-- Innovation -->
            <div class="col-md-4 mb-4">
                <div class="text-center">
                    <div class="mb-3">
                        <i class="fas fa-lightbulb fa-4x" style="color: #FF8500;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Innovation</h4>
                    <p class="text-muted">
                        We constantly innovate our menu and services to bring you new flavors 
                        and better experiences.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Statistics Section -->
<section class="py-5 bg-dark text-white">
    <div class="container">
        <div class="row text-center">
            <!-- Happy Customers -->
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="mb-2">
                    <i class="fas fa-users fa-3x"></i>
                </div>
                <h3 class="display-4 fw-bold">10K+</h3>
                <p class="lead">Happy Customers</p>
            </div>
            <!-- Menu Items -->
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="mb-2">
                    <i class="fas fa-hamburger fa-3x"></i>
                </div>
                <h3 class="display-4 fw-bold">500+</h3>
                <p class="lead">Menu Items</p>
            </div>
            <!-- Deliveries -->
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="mb-2">
                    <i class="fas fa-motorcycle fa-3x"></i>
                </div>
                <h3 class="display-4 fw-bold">50K+</h3>
                <p class="lead">Deliveries</p>
            </div>
            <!-- Average Rating -->
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="mb-2">
                    <i class="fas fa-star fa-3x"></i>
                </div>
                <h3 class="display-4 fw-bold">4.8</h3>
                <p class="lead">Average Rating</p>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Why Choose Tasty Bites?</h2>
            <p class="lead text-muted">What makes us different</p>
        </div>
        <div class="row">
            <!-- Fresh Ingredients -->
            <div class="col-md-6 mb-4">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-check-circle fa-2x me-3" style="color: #6A994E;"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold">Fresh Ingredients</h5>
                        <p class="text-muted">We source the freshest ingredients daily from trusted suppliers.</p>
                    </div>
                </div>
            </div>
            <!-- Expert Chefs -->
            <div class="col-md-6 mb-4">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-check-circle fa-2x me-3" style="color: #6A994E;"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold">Expert Chefs</h5>
                        <p class="text-muted">Our experienced chefs bring passion and expertise to every dish.</p>
                    </div>
                </div>
            </div>
            <!-- Wide Variety -->
            <div class="col-md-6 mb-4">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-check-circle fa-2x me-3" style="color: #6A994E;"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold">Wide Variety</h5>
                        <p class="text-muted">From comfort food to exotic cuisines, we have something for everyone.</p>
                    </div>
                </div>
            </div>
            <!-- Fast Delivery -->
            <div class="col-md-6 mb-4">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-check-circle fa-2x me-3" style="color: #6A994E;"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold">Fast Delivery</h5>
                        <p class="text-muted">Hot and fresh food delivered to your door in no time.</p>
                    </div>
                </div>
            </div>
            <!-- Easy Ordering -->
            <div class="col-md-6 mb-4">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-check-circle fa-2x me-3" style="color: #6A994E;"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold">Easy Ordering</h5>
                        <p class="text-muted">Simple and convenient online ordering system.</p>
                    </div>
                </div>
            </div>
            <!-- Great Value -->
            <div class="col-md-6 mb-4">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-check-circle fa-2x me-3" style="color: #6A994E;"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold">Great Value</h5>
                        <p class="text-muted">Competitive prices and regular special offers and discounts.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="py-5 text-white text-center" style="background-color: #C1121F;">
    <div class="container">
        <h2 class="display-5 fw-bold mb-3">Ready to Order?</h2>
        <p class="lead mb-4">Explore our delicious menu and place your order today!</p>
        <a href="@Url.Action("Menu", "Home")" class="btn btn-light btn-lg px-5">
            <i class="fas fa-utensils me-2"></i>View Menu
        </a>
    </div>
</section>

<style>
    .about-hero {
        position: relative;
        overflow: hidden;
    }

    .about-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(255,255,255,0.1)" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,112C672,96,768,96,864,112C960,128,1056,160,1152,160C1248,160,1344,128,1392,112L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
        opacity: 0.3;
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
    }
</style>
